{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "dialog:allow-open",
    "dialog:allow-confirm",
    "dialog:allow-ask",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-exists",
    "fs:allow-copy-file",
    "fs:allow-mkdir",
    "fs:scope-appdata-recursive"
  ]
}
