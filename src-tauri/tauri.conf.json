{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MangAI Translator",
  "version": "0.1.2",
  "identifier": "com.levib.mangaitranslator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MangAI Translator",
        "width": 1280,
        "height": 720,
        "maximized": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost",
          "https://generativelanguage.googleapis.com",
          "http://localhost:11434",
          "http://127.0.0.1:11434"
        ],
        "img-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "data:",
          "blob:"
        ]
      },
      "freezePrototype": true,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/cache/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Zentsy",
    "createUpdaterArtifacts": true,
    "targets": "nsis",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "languages": ["PortugueseBR", "English"],
        "displayLanguageSelector": false
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENCQTA2Q0ZDMUZDQThDNgpSV1RHcVB6Qnp3YTZES3pLSHB4dFdWdCsrZ1hzNnVhOE9IREdFVFVxRUFWdkN1SWw2VFB5aVVLeAo=",
      "endpoints": [
        "https://github.com/Zentsy/MangAItranslator/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
